001b[38;2;114;114;114m\u001b[49mrent us\u001b[0m\u001b[12;47H\u001b[38;2;114;114;114m\u001b[49mr)\u001b[0m\u001b[13;6H\u001b[38;2;255;255;255m\u001b[49m                           \u001b[0m\u001b[14;6H\u001b[38;2;114;114;114m\u001b[49mTo test if AI in\u001b[0m\u001b[14;23H\u001b[38;2;114;114;114m\u001b[49ma Box is working, I need to:\u001b[0m\u001b[15;6H\u001b[38;2;138;85;8m\u001b[49m1. \u001b[0m\u001b[15;9H\u001b[38;2;114;114;114m\u001b[49mCreate a record with u_prompt filled in\u001b[0m\u001b[16;6H\u001b[38;2;138;85;8m\u001b[49m2. \u001b[0m\u001b[16;9H\u001b[38;2;114;114;114m\u001b[49mThe state should be\u001b[0m\u001b[16;29H\u001b[38;2;114;114;114m\u001b[49m\"ne\u001b[0m\u001b[16;33H\u001b[38;2;114;114;114m\u001b[49m\" initially\u001b[0m\u001b[16;44H\u001b[38;2;255;255;255m\u001b[49m       \u001b[0m\u001b[17;6H\u001b[38;2;138;85;8m\u001b[49m3\u001b[0m\u001b[17;9H\u001b[38;2;114;114;114m\u001b[49mTh\u001b[0m\u001b[17;12H\u001b[38;2;114;114;114m\u001b[49m business \u001b[0m\u001b[17;23H\u001b[38;2;114;114;114m\u001b[49mule \"Fetch Inference\" should trigger when the record is created and send the \u001b[0m\u001b[18;6H\u001b[38;2;114;114;114m\u001b[49mrequest \u001b[0m\u001b[18;15H\u001b[38;2;114;114;114m\u001b[49mo AI in a Box\u001b[0m\u001b[18;28H\u001b[38;2;255;255;255m\u001b[49m                \u001b[0m\u001b[19;6H\u001b[38;2;255;255;255m\u001b[49m                                                                                              \u001b[0m\u001b[20;6H\u001b[38;2;114;114;114m\u001b[49mL\u001b[0m\u001b[20;8H\u001b[38;2;114;114;114m\u001b[49mt me create\u001b[0m\u001b[20;20H\u001b[38;2;114;114;114m\u001b[49ma simple test record with a prompt like \"Say hello and confirm you are working\".\u001b[0m\u001b[21;3H\u001b[38;2;255;255;255m\u001b[49m \u001b[0m\u001b[22;3H\u001b[38;2;255;255;255m\u001b[49m \u001b[0m\u001b[22;6H\u001b[38;2;190;190;190m\u001b[49mI can see the table structure. The key fields are:\u001b[0m\u001b[22;56H\u001b[38;2;255;255;255m\u001b[49m                                            \u001b[0m\u001b[23;6H\u001b[38;2;230;142;13m\u001b[49m- \u001b[0m\u001b[23;8H\u001b[38;2;190;190;190m\u001b[49m\u001b[1mu_prompt\u001b[0m\u001b[23;16H\u001b[38;2;190;190;190m\u001b[49m - The prompt to send to the AI\u001b[0m\u001b[24;6H\u001b[38;2;230;142;13m\u001b[49m- \u001b[0m\u001b[24;8H\u001b[38;2;190;190;190m\u001b[49m\u001b[1mu_state\u001b[0m\u001b[24;16H\u001b[38;2;190;190;190m\u001b[49m- Starts a\u001b[0m\u001b[24;27H\u001b[38;2;190;190;190m\u001b[49m \"new\", changes to \"request\u001b[0m\u001b[24;55H\u001b[38;2;190;190;190m\u001b[49md\" when processing\u001b[0m\u001b[25;10H\u001b[38;2;190;190;190m\u001b[49m\u001b[1mtype\u001b[0m\u001b[25;14H\u001b[38;2;190;190;190m\u001b[49m -\u001b[0m\u001b[25;17H\u001b[38;2;190;190;190m\u001b[49mDefaults to \"generic\"\u001b[0m\u001b[25;38H\u001b[38;2;255;255;255m\u001b[49m         \u001b[0m\u001b[26;10H\u001b[38;2;190;190;190m\u001b[49m\u001b[1mmodel\u001b[0m\u001b[26;18H\u001b[38;2;190;190;190m\u001b[49mUses the property setting by d\u001b[0m\u001b[26;49H\u001b[38;2;190;190;190m\u001b[49mfaul\u001b[0m\u001b[26;54H\u001b[38;2;255;255;255m\u001b[49m                   \u001b[0m\u001b[27;6H\u001b[38;2;255;255;255m\u001b[49m                                \u001b[0m\u001b[28;6H\u001b[38;2;190;190;190m\u001b[49mLet me create a test\u001b[0m\u001b[28;26H\u001b[38;2;255;255;255m\u001b[49m                    \u001b[0m\u001b[0m\u001b[33;6H\u001b[?25h\u001b[?2026l"]
