[0.000, "o", "\u001b[?2004l\r"]
[0.005, "o", "List, show, create, update, and delete records from any ServiceNow table via the Table API.\r\n\r\n"]
[0.000, "o", "Usage:\r\n  jsn records [command]\r\n\r\nAvailable Commands:\r\n  count       Count records in a table\r\n  create      Create a new record\r\n  delete      Delete a record\r\n  list        List records from a table\r\n  query       Query records with raw encoded query\r\n  show        Show record details\r\n  update      Update an existing record\r\n  variables   Show all variables (single-row and MRVS) for a request item\r\n\r\nFlags:\r\n  -h, --help   help for records\r\n\r\nGlobal Flags:\r\n      --agent            Agent mode (JSON + quiet + no interactive prompts)\r\n      --config string    config file (default is $HOME/.config/servicenow/config.json)\r\n      --jq string        Apply jq filter to JSON output\r\n      --json             Output as JSON\r\n      --md               Output as Markdown\r\n      --no-interactive   Disable interactive prompts (for scripts/CI)\r\n  -p, --profile string   profile to use\r\n  -q, --quiet            Quiet output (data only, no envelope)\r\n\r\nUse \"jsn records [command] --help\" for more information about a command.\r\n"]
