33;33;33m_type\": \"integer\",\u001b[0m\u001b[17;15H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mref\u001b[0m\u001b[17;20H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mence\": \"\u001b[0m\u001b[17;29H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m,\u001b[0m\u001b[17;30H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m           \u001b[0m\u001b[18;15H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mmandatory\u001b[0m\u001b[18;28H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mfalse\",\u001b[0m\u001b[19;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m…\u001b[19;7H\u001b[0m\u001b[19;7H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                            \u001b[0m\u001b[20;6H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m \u001b[0m\u001b[21;6H\u001b[38;2;165;165;165m\u001b[48;2;33;33;33mClick to expand\u001b[0m\u001b[22;6H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m               \u001b[0m\u001b[23;3H\u001b[38;2;255;255;255m\u001b[49m                                                                                                     \u001b[0m\u001b[24;3H\u001b[38;2;41;41;41m\u001b[49m┃\u001b[0m\u001b[24;6H\u001b[38;2;111;17;17m\u001b[49m\u001b[3mThinking:\u001b[0m\u001b[24;15H\u001b[38;2;114;114;114m\u001b[49m I can see the u_ai_inference table structure. The key fields are:\u001b[0m\u001b[25;6H\u001b[38;2;138;85;8m\u001b[49m- \u001b[0m\u001b[25;8H\u001b[38;2;114;114;114m\u001b[49mu_prompt (the\u001b[0m\u001b[25;22H\u001b[38;2;114;114;114m\u001b[49mprompt to send to the AI)\u001b[0m\u001b[25;47H\u001b[38;2;255;255;255m\u001b[49m                                  \u001b[0m\u001b[26;10H\u001b[38;2;114;114;114m\u001b[49mtype (default: \"generic\")\u001b[0m\u001b[26;35H\u001b[38;2;255;255;255m\u001b[49m            \u001b[0m\u001b[27;10H\u001b[38;2;114;114;114m\u001b[49mstate (default: \"new\" - this is important because the business rule triggers on state change)\u001b[0m\u001b[28;10H\u001b[38;2;114;114;114m\u001b[49mmodel\u001b[0m\u001b[28;24H\u001b[38;2;114;114;114m\u001b[49ms\u001b[0m