[0.000, "o", "  \u001b[1;38;2;232;162;23mQuery\u001b[0m\r\n    • \u001b[38;2;136;136;136moperators\u001b[0m\r\n\r\n"]
[0.001, "o", "  \u001b[1;38;2;232;162;23mClient-side\u001b[0m\r\n    • \u001b[38;2;136;136;136mglideform\u001b[0m\r\n"]
[0.000, "o", "    • \u001b[38;2;136;136;136mglideuser\u001b[0m\r\n"]
[0.000, "o", "    • \u001b[38;2;136;136;136mglideajax\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  \u001b[1;38;2;232;162;23mServer-side\u001b[0m\r\n    • \u001b[38;2;136;136;136mglidesystem\u001b[0m\r\n"]
