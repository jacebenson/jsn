[0.019, "o", "\u001b[?2026h\u001b[?25l\u001b[2;6H\u001b[38;2;114;114;114m\u001b[49mTo test if AI in\u001b[0m\u001b[2;23H\u001b[38;2;114;114;114m\u001b[49ma Box is working, I need to:\u001b[0m\u001b[3;6H\u001b[38;2;138;85;8m\u001b[49m1. \u001b[0m\u001b[3;9H\u001b[38;2;114;114;114m\u001b[49mCreate a record with u_prompt filled in\u001b[0m\u001b[4;6H\u001b[38;2;138;85;8m\u001b[49m2. \u001b[0m\u001b[4;9H\u001b[38;2;114;114;114m\u001b[49mThe state should be\u001b[0m\u001b[4;29H\u001b[38;2;114;114;114m\u001b[49m\"ne\u001b[0m\u001b[4;33H\u001b[38;2;114;114;114m\u001b[49m\" initially\u001b[0m\u001b[4;44H\u001b[38;2;255;255;255m\u001b[49m       \u001b[0m\u001b[5;6H\u001b[38;2;138;85;8m\u001b[49m3\u001b[0m\u001b[5;9H\u001b[38;2;114;114;114m\u001b[49mTh\u001b[0m\u001b[5;12H\u001b[38;2;114;114;114m\u001b[49m business \u001b[0m\u001b[5;23H\u001b[38;2;114;114;114m\u001b[49mule \"Fetch Inference\" should trigger when the record is created and send the \u001b[0m\u001b[6;6H\u001b[38;2;114;114;114m\u001b[49mrequest \u001b[0m\u001b[6;15H\u001b[38;2;114;114;114m\u001b[49mo AI in a Box\u001b[0m\u001b[6;28H\u001b[38;2;255;255;255m\u001b[49m                \u001b[0m\u001b[7;6H\u001b[38;2;255;255;255m\u001b[49m                                                                                              \u001b[0m\u001b[8;6H\u001b[38;2;114;114;114m\u001b[49mL\u001b[0m\u001b[8;8H\u001b[38;2;114;114;114m\u001b[49mt me create\u001b[0m\u001b[8;20H\u001b[38;2;114;114;114m\u001b[49ma simple test record with a prompt like \"Say hello and confirm you are working\".\u001b[0m\u001b[9;3H\u001b[38;2;255;255;255m\u001b[49m \u001b[0m\u001b[10;3H\u001b[38;2;255;255;255m\u001b[49m \u001b[0m\u001b[10;6H\u001b[38;2;190;190;190m\u001b[49mI can see the table structure. The key fields are:\u001b[0m\u001b[10;56H\u001b[38;2;255;255;255m\u001b[49m                                            \u001b[0m\u001b[11;6H\u001b[38;2;230;142;13m\u001b[49m- \u001b[0m\u001b[11;8H\u001b[38;2;190;190;190m\u001b[49m\u001b[1mu_promp