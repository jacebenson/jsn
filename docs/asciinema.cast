[0.000, "o", "\u001b[38;2;166;226;46m<div ng-if=\"options.action_group\" class=\"action-container\" ng-style=\"c.getFlexDirection()\">\u001b[0m                                                                                                                                                                                                                                                                                                                                                        \r\n\u001b[38;2;166;226;46m        <div ng-if=\"data.actionButtons.length > 0\" class=\"button-container\" ng-style=\"c.getFlexDirection()\">\u001b[0m                                                                                                                                                                                                                                                                                                                                       \r\n\u001b[38;2;166;226;46m          <a ng-repeat=\"action in data.actionButtons\" class=\"btn actions primary-action\" ng-class=\"{'btn-primary' : action.primary && data.primary_colored_button, 'action-btn' : (data.max_button_count > 1), 'btn-default' : (!action.primary || !data.primary_colored_button) }\" tabindex=\"0\" role=\"button\" ng-keydown=\"c.handleEnterKeyPress($event,action)\" ng-click=\"handleClick(action)\"\u001b[0m                                                    \r\n\u001b[38;2;166;226;46m             data-container=\"body\" data-title=\"{{action.actionName}}\">\u001b[0m                                                                                                                                                                                                                                                                                                                                                                             \r\n\u001b[38;2;166;226;46m            <span ng-if=\"action.actionIcon\" class=\"fa fa-{{action.actionIcon}} icon\"/>\u001b[0m                                                                                                                                                                                                                                                                                                                                                             \r\n\u001b[38;2;166;226;46m            <div class=\"text-wrap\">{{action.actionName}}</div>\u001b[0m                                                                                                                                                                                                                                                                                                                                                                                     \r\n\u001b[38;2;166;226;46m          </a>\u001b[0m                                                                                                                                                                                                                                                                                                                                                                                                                                     \r\n\u001b[38;2;166;226;46m        </div>\u001b[0m                                                                                                                                                                                                                                                                                                                                                                                                                                     \r\n\u001b[38;2;166;226;46m        <div ng-if=\" data.otherActions && data.otherActions.length > 0\" class=\"dropdown btn-group\" id=\"action-dropdown\" ng-class=\"{'dropup' : (data.button_direction_reversed)}\">\u001b[0m                                                                                                                                                                                                                                                                  \r\n"]
[0.000, "o", "\u001b[38;2;166;226;46m          <button type=\"button\" class=\"btn btn-default\" ng-class=\"{'action-btn' : (data.max_button_count > 1) ,'more-btn' : (data.max_button_count==0) }\"  ng-click=\"dropdownToggle(this)\" data-toggle=\"dropdown\" aria-haspopup=\"false\" aria-label=\"${View menu}\" data-toggle-tooltip=\"tooltip\" data-placement=\"{{data.button_direction_reversed ? 'bottom' :'auto'}}\" title=\"${View menu}\" data-boundary=\"viewport\" data-fallbackPlacement=\"flip\">\u001b[0m\r\n\u001b[38;2;166;226;46m            <div class=\"text-wrap\" ng-if=\"data.overflowbtnlabel\">{{data.overflowbtnlabel}}</div><span class=\"fa {{data.more_icon}} icon-center\"></span>\u001b[0m                                                                                                                                                                                                                                                                                            \r\n\u001b[38;2;166;226;46m          </button>\u001b[0m                                                                                                                                                                                                                                                                                                                                                                                                                                \r\n\u001b[38;2;166;226;46m          <ul class=\"dropdown-menu  {{data.button_direction_reversed ? 'dropdown-menu-reversed' :'dropdown-menu-right'}} \" ng-style=\"c.getDropdownWidth()\" id=\"actionList\" role=\"menubar\">\u001b[0m                                                                                                                                                                                                                                                         \r\n\u001b[38;2;166;226;46m            <li role=\"presentation\" ng-repeat=\"action in data.otherActions\">\u001b[0m                                                                                                                                                                                                                                                                                                                                                                       \r\n\u001b[38;2;166;226;46m              <a tabindex=\"0\" role=\"menuitem\" ng-keydown=\"c.handleEnterKeyPress($event,action)\" ng-click =\"handleClick(action)\" class=\"text-wrap\" data-title=\"{{action.actionName}}\" aria-label=\"{{action.actionName}}\">{{action.actionName}}</a>\u001b[0m                                                                                                                                                                                                  \r\n\u001b[38;2;166;226;46m            </li>\u001b[0m                                                                                                                                                                                                                                                                                                                                                                                                                                  \r\n\u001b[38;2;166;226;46m          </ul>\u001b[0m                                                                                                                                                                                                                                                                                                                                                                                                                                    \r\n\u001b[38;2;166;226;46m        </div>\u001b[0m                                                                                                                                                                                                                                                                                                                                                                                                                                     \r\n"]
