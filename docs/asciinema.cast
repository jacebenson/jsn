[0.046, "o", "\u001b[?2026h\u001b[?25l\u001b[2;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m  Use --field (or -f) to set field values: --field short_description=\"Server down\"\u001b[0m\u001b[3;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m  Use\u001b[0m\u001b[3;12H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m--json to provide a JSON object: --json '{\"short_description\":\"Server down\"}'\u001b[0m\u001b[4;6H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                                                                                  \u001b[0m\u001b[5;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mInteractive Mode:\u001b[0m\u001b[5;23H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                                                                  \u001b[0m\u001b[6;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m  If no table is provided, an interactive picker will help you select one.\u001b[0m\u001b[7;6H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                 \u001b[0m\u001b[8;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mExamples:\u001b[0m\u001b[8;15H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                                                                 \u001b[0m\u001b[9;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m…\u001b[9;7H\u001b[0m\u001b[10;6H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m         \u001b[0m\u001b[11;6H\u001b[38;2;165;165;165m\u001b[48;2;33;33;33mClick to expand\u001b[0m\u001b[13;3H\u001b[38;2;255;255;255m\u001b[49m                                                                                                     \u001b[0m\u001b[14;3H\u001b[38;2;41;41;41m\u001b[49m┃\u001b[0m\u001b[14;4H\u001b[38;2;255;255;255m\u001b[49m  \u001b[0m\u001b[14;6H\u001b[38;2;111;17;17m\u001b[49m\u001b[3mThinking:\u001b[0m\u001b[14;15H\u001b[38;2;114;114;114m\u001b[49m I see, I need to use --field or --json (lowercase). Let me try with --field flags.\u001b[0m\u001b[14;98H\u001b[38;2;255;255;255m\u001b[49m      \u001b[0m\u001b[16;3H\u001b[38;2;255;255;255m\u001b[49m \u001b[0m\u001b[16;6H\u001b[38;2;190;190;190m\u001b[49mNow I understand - need to use \u001b[0m\u001b[16;37H\u001b[38;2;255;193;7m\u001b[49m--field\u001b[0m\u001b[16;44H\u001b[38;2;190;190;190m\u001b[49m flags. Let me create the test record:\u001b[0m\u001b[16;82H\u001b[38;2;255;255;255m\u001b[49m                \u001b[0m\u001b[18;3H\u001b[38;2;0;0;0m\u001b[48;2;33;33;33m┃\u001b[0m\u001b[18;4H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                                                                                                    \u001b[0m\u001b[19;3H\u001b[38;2;0;0;0m\u001b[48;2;33;33;33m┃\u001b[0m\u001b[19;4H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m  \u001b[0m\u001b[19;6H\u001b[38;2;165;165;165m\u001b[48;2;33;33;33m# Create test AI inference record\u001b[0m\u001b[19;39H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                                                                 \u001b[0m\u001b[21;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m$ jsn records create u_ai_inference --field u_prompt=\"Hello! Please respond with a short \u001b[0m\u001b[22;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mconfirmation that you are working. Just say something like 'AI in a Box is working correctly!'\" --\u001b[0m\u001b[23;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mfield\u001b[0m\u001b[23;12H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mu_type=gen\u001b[0m\u001b[23;23H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mric\u001b[0m\u001b[23;27H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33m--json\u001b[0m\u001b[23;33H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                                                              \u001b[0m\u001b[24;6H\u001b[38;2;255;255;255m\u001b[48;2;33;33;33m                                                                                                  \u001b[0m\u001b[25;6H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mError: flag ne\u001b[0m\u001b[25;21H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33mds an\u001b[0m\u001b[25;27H\u001b[38;2;190;190;190m\u001b[48;2;33;33;33margument: --json\u001b[0m\u001b[27;3H\u001b[38;2;255;255;255m\u001b[49m                                                                                                     \u001b[0m\u001b[28;3H\u001b[38;2;41;41;41m\u001b[49m┃\u001b[0m\u001b[28;4H\u001b[38;2;255;255;255m\u001b[49m                                                                                                    \u001b[0m\u001b[0m\u001b[33;6H\u001b[?25h\u001b[?2026l"]
