[0.038, "o", "\u001b[1;38;2;232;162;23mAvailable Documentation Topics\u001b[0m\r\n\r\n  \u001b[1;38;2;232;162;23mAPI Reference\u001b[0m\r\n"]
[0.000, "o", "    • \u001b[38;2;136;136;136mgliderecord\u001b[0m\r\n    • \u001b[38;2;136;136;136mglidequery\u001b[0m\r\n"]
