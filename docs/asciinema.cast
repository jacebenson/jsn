[0.001, "o", "\u001b[?2004l\r"]
[0.006, "o", "List and view ServiceNow Service Portal Widgets (global, not portal-specific).\r\n\r\n"]
[0.000, "o", "Usage:\r\n  jsn sp-widgets [command]\r\n\r\nAliases:\r\n  sp-widgets, sp-widget, widgets, widget\r\n\r\nAvailable Commands:\r\n  list        List Service Portal Widgets\r\n  show        Show widget details\r\n\r\nFlags:\r\n  -h, --help   help for sp-widgets\r\n\r\nGlobal Flags:\r\n      --agent            Agent mode (JSON + quiet + no interactive prompts)\r\n      --config string    config file (default is $HOME/.config/servicenow/config.json)\r\n      --jq string        Apply jq filter to JSON output\r\n      --json             Output as JSON\r\n      --md               Output as Markdown\r\n      --no-interactive   Disable interactive prompts (for scripts/CI)\r\n  -p, --profile string   profile to use\r\n  -q, --quiet            Quiet output (data only, no envelope)\r\n\r\n"]
[0.000, "o", "Use \"jsn sp-widgets [command] --help\" for more information about a command.\r\n"]
[0.008, "o", "\u001b]0;jace@framework:~/git/aiinabox\u0007"]
