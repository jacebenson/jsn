o:\u001b[0m\u001b[13;6H\u001b[38;2;138;85;8m\u001b[49m1. \u001b[0m\u001b[13;9H\u001b[38;2;114;114;114m\u001b[49mCreate a record\u001b[0m\u001b[13;25H\u001b[38;2;114;114;114m\u001b[49mwith u_prompt filled in\u001b[0m\u001b[13;48H\u001b[38;2;255;255;255m\u001b[49m   \u001b[0m\u001b[14;6H\u001b[38;2;138;85;8m\u001b[49m2\u001b[0m\u001b[14;9H\u001b[38;2;114;114;114m\u001b[49mTh\u001b[0m\u001b[14;12H\u001b[38;2;114;114;114m\u001b[49m state sh\u001b[0m\u001b[14;22H\u001b[38;2;114;114;114m\u001b[49muld be \"new\" initia\u001b[0m\u001b[14;43H\u001b[38;2;114;114;114m\u001b[49my\u001b[0m\u001b[14;44H\u001b[38;2;255;255;255m\u001b[49m    \u001b[0m\u001b[15;6H\u001b[38;2;138;85;8m\u001b[49m3\u001b[0m\u001b[15;13H\u001b[38;2;114;114;114m\u001b[49mbusine\u001b[0m\u001b[15;20H\u001b[38;2;114;114;114m\u001b[49ms rule \"Fetch Inference\" should trigger when the record is created and send the \u001b[0m\u001b[16;6H\u001b[38;2;114;114;114m\u001b[49mrequest to AI in a Box\u001b[0m\u001b[16;28H\u001b[38;2;255;255;255m\u001b[49m                                                                        \u001b[0m\u001b[17;6H\u001b[38;2;255;255;255m\u001b[49m                      \u001b[0m\u001b[18;6H\u001b[38;2;114;114;114m\u001b[49mLet me create a simple test record with a prompt like \"Say hello and confirm you are working\".\u001b[0m\u001b[19;3H\u001b[38;2;255;255;255m\u001b[49m \u001b[0m\u001b[19;6H\u001b[38;2;255;255;255m\u001b[49m                                                                                              \u001b[0m\u001b[20;6H\u001b[38;2;190;190;190m\u001b[49mI can see the table structure. The key fields are:\u001b[0m\u001b[21;6H\u001b[38;2;230;142;13m\u001b[49m- \u001b[0m\u001b[21;8H\u001b[38;2;190;190;190m\u001b[49m\u001b[1mu_prompt\u001b[0m\u001b[21;16H\u001b[38;2;190;190;190m\u001b[49m - The prompt to s\u001b[0m\u001b[21;35H\u001b[38;2;190;190;190m\u001b[49mnd to\u001b[0m\u001b[21;41H\u001b[38;2;190;190;190m\u001b[49mthe\u001b[0m\u001b[21;45H\u001b[38;2;190;190;190m\u