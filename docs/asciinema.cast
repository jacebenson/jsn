[0.017, "o", "\u001b[1;38;2;232;162;23mSelect a widget:\u001b[0m\r\r\n\r\r\n\u001b[38;2;136;136;136mNo items found\u001b[0m\r\r\n\u001b[38;2;136;136;136m↑/↓/jk navigate • enter select • esc cancel\u001b[0m\r\r\n\u001b[150D"]
[0.216, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[150D\u001b[2K\u001b[1;38;2;232;162;23mSelect a widget:\u001b[0m\r\r\n\r\r\n\u001b[38;2;232;162;23m> \u001b[0m\u001b[1mActions Widget (action-widget)\u001b[0m\u001b[38;2;136;136;136m - Widget that handles the load and display of Actions defined.\u001b[0m\r\r\n  Add Widget (widget-add-new)\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n  AI Search Assist (ai-search-assist)\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n  AIAB Chat (aiab_chat)\u001b[38;2;136;136;136m - AI In A Box floating chat widget with real-time streaming responses. Customizable via CSS variables.\u001b[0m\r\r\n  AIAB GetHelp (aiab_get_help)\u001b[38;2;136;136;136m - Scope: AI in a Box\u001b[0m\r\r\n  AIAB How it works (aiab_how_it_works)\u001b[38;2;136;136;136m - Scope: AI in a Box\u001b[0m\r\r\n  AIAB Portal Search (aiab-portal-search)\u001b[38;2;136;136;136m - Scope: AI in a Box\u001b[0m\r\r\n  AIAB Server (aiab_server)\u001b[38;2;136;136;136m - Scope: AI in a Box\u001b[0m\r\r\n  AIAB Settings (aiab_settings)\u001b[38;2;136;136;136m - Scope: AI in a Box\u001b[0m\r\r\n  AIS Topic Search (ais_topic_search)\u001b[38;2;136;136;136m - Search inputbox for topic search with autocomplete functionality.\u001b[0m\r\r\n  Announcements (announcements)\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n  Approval Info\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n  Approval Info Record\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n  Approval Record\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n  Approvals\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n\r\r\n\u001b[38;2;136;136;136mShowing 1-15+\u001b[0m\r\r\n\u001b[38;2;136;136;136m↑/↓/jk navigate • enter select • esc cancel\u001b[0m\r\r\n\u001b[150D"]
[0.767, "o", "\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[1A\u001b[150D\u001b[2K\u001b[1;38;2;232;162;23mSelect a widget:\u001b[0m\r\r\n\u001b[1B  Actions Widget (action-widget)\u001b[38;2;136;136;136m - Widget that handles the load and display of Actions defined.\u001b[0m\r\r\n\u001b[38;2;232;162;23m> \u001b[0m\u001b[1mAdd Widget (widget-add-new)\u001b[0m\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[150D"]
[0.117, "o", "\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[1A\u001b[1A\u001b[150D\u001b[2K\u001b[1;38;2;232;162;23mSelect a widget:\u001b[0m\r\r\n\u001b[1B\u001b[1B  Add Widget (widget-add-new)\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n\u001b[38;2;232;162;23m> \u001b[0m\u001b[1mAI Search Assist (ai-search-assist)\u001b[0m\u001b[38;2;136;136;136m - Scope: Global\u001b[0m\r\r\n\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[1B\u001b[150D"]
